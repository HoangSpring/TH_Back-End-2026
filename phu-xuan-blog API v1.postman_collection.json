          "listen": "test",
          "script": {
            "exec": [
              "// Kiểm tra xem Backend có trả về đúng mã trạng thái 201 Created hay không\r",
              "pm.test(\"Status code is 201\", () => {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// Tự động lấy ID của bài viết vừa sinh ra trong database để lưu vào bộ nhớ Postman\r",
              "const json = pm.response.json();\r",
              "if(json.data && json.data.id) {\r",
              "    pm.collectionVariables.set(\"post_id\", json.data.id);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
